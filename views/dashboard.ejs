<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>

      <a href="/">Home</a>


    <% if (user) { %>
        <a href="/logout">Logout</a>
        <h1>Welcome, <%= user.name %>!</h1>
        <p>Last Name: <%= user.last_name %></p>
        <p>Username: <%= user.username %></p>


        <% if (user.is_admin === false) { %>
           <form action="/createAdmin" method="POST">
            <input type="text" name="adminPasscode" placeholder="Admin Passcode" id="adminPasscode" required/>

             <button type="submit">Create Admin</button>
           </form>
       <% } %>


            <% if (user.membership_status === 'regular') { %>
                
                <h1>Join the club</h1>

                <% if (errorsJoin && errorsJoin.length > 0) { %>
    <ul style="color: red;">
      <% errorsJoin.forEach(function(error) { %>
        <li><%= error.msg %></li>
      <% }); %>
    </ul>
  <% } %>

             <form action="/join" method="POST">
            <input type="text" name="joinPasscode" placeholder="Join Passcode" id="joinPasscode" required />
             <button type="submit">Join the club</button>
           </form>
            <% } else { %>
           
            <p>You are mbr/go check msg</p>
        <% } %>

          


        <% } else { %>
            <h1>Welcome to the Dashboard</h1>
            <p>Please log in to see your information.</p>
        <% } %>
</body>
</html>