<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>
    <div class="container">

        <!-- Welcome Section -->
        <div class="flexleft">
            <% if (user) { %>
                <h4>Welcome, <%= user.username || user.name %>!</h4>
                <p><strong>Name:</strong> <%= user.name || 'N/A' %></p>
                <p><strong>Last Name:</strong> <%= user.last_name || 'N/A' %></p>
                <p><strong>Username:</strong> <%= user.username || 'N/A' %></p>
            <% } else { %>
              
                <p>Please <a href="/">login</a> to see your information.</p>
            <% } %>
        </div>

        <!-- Admin & Membership Section -->
        <% if (user) { %>

            <div>

                <!-- Admin Section -->
                <% if (user.is_admin === false || user.is_admin == null) { %>
                    <% if (errorsAdmin && errorsAdmin.length > 0) { %>
                        <ul style="color: red;">
                            <% errorsAdmin.forEach(function(error) { %>
                                <li><%= error.msg %></li>
                            <% }); %>
                        </ul>
                    <% } %>

                    <h3>Become an Admin</h3>
                    <form action="/createAdmin" method="POST">
                        <input type="text" 
                               name="adminPasscode" 
                               placeholder="Passcode = admin" 
                               id="adminPasscode" 
                               required />
                        <button type="submit">Create Admin</button>
                    </form>
                    <p>As an admin you will be able to delete any message.</p>

                <% } else { %>
                    <p>✅ You are an <strong>Admin</strong>. You can delete messages.</p>
                <% } %>

                <hr>

                <!-- Membership Section -->
                <% if (user.membership_status === 'regular') { %>
                    <% if (errorsJoin && errorsJoin.length > 0) { %>
                        <ul style="color: red;">
                            <% errorsJoin.forEach(function(error) { %>
                                <li><%= error.msg %></li>
                            <% }); %>
                        </ul>
                    <% } %>

                    <h3>Join the Club</h3>
                    <form action="/join" method="POST">
                        <input type="text" 
                               name="joinPasscode" 
                               placeholder="Passcode = 401" 
                               id="joinPasscode" 
                               required />
                        <button type="submit">Join the Club</button>
                    </form>
                    <p>The author and date of messages are visible only to club members.</p>

                <% } else { %>
                    <p>✅ You are a <strong>Club Member</strong>. Author and date information is visible to you.</p>
                <% } %>

            </div>

        <% } %>

    </div>
</main>

<%- include('partials/footer') %>