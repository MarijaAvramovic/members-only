 

<%- include('partials/head') %>

<%- include('partials/nav') %>

 <main>

    <div class="container">

         <div>
             <% if (user) { %>
    
      
            
   
    <form class="addmessage-form"  method="POST" action="/add-message">
        <input name="title" placeholder="Title" required type="text" />
        <textarea name="text" placeholder="Message text" required></textarea>
        <button type="submit">Send</button>
    </form>
        <% } else { %>
         </div>
         
       
 
       

 
  
     <div>    
        
 <form class="login-form" method="POST" action="/login">
  <input type="text" name="username" placeholder="Username" required />
  <input type="password" name="password" placeholder="Password" required />
  <button type="submit">Login</button>
</form>

        <% } %>
</div>

            <div>
                <h1>Messages</h1>

     
        <% messages.forEach(message => { %>
             <div>
                <h2><%= message.title %></h2>
                
                <p><%= message.text %></p>





                <p>
                    
                     <% if (user && (message.user_id === user.id || user.membership_status === 'member' || user.is_admin === true)) { %>
                        Posted by: <%= message.user_username %>
                      <%= message.timestamp.toLocaleDateString() %> 
               <%= message.timestamp.toLocaleTimeString()   %> 
               <% } %>
                    


                     

                </p>






                
             </div><span>          
            
                 <% if (user && user.is_admin) { %>
                       <a href="/messages/<%= message.id %>/delete" 
       onclick="return confirm('Are you sure you want to delete this message?')">
        Delete
    </a>
                        <% } %>
            </span>
        <% }); %>
            </div>
     

         
     
</div>

    

 

</div>




    
</main>

 
    
    
   
 <%- include('partials/footer') %>