 

<%- include('partials/head') %>

<%- include('partials/nav') %>

 <main>
    <div class="container">
         
         
        <% if (user) { %>
            Welcome, <%= user.username %>!
            <p>Comment...</p>
            
   
    <form method="POST" action="/add-message">
        <input name="title" placeholder="Title" required />
        <textarea name="text" placeholder="Message text" required></textarea>
        <button type="submit">Send</button>
    </form>
</div>

        <% } else { %>
            Please log in to send messages.
            <form method="POST" action="/login">
  <input name="username" placeholder="Username" required />
  <input type="password" name="password" placeholder="Password" required />
  <button type="submit">Login</button>
</form>
        <% } %>
    </h2>

 

</div>
    <h1>Messages</h1>
     
        <% messages.forEach(message => { %>
             <div>
                <h2><%= message.title %></h2>
                
                <p><%= message.text %></p>





                <p>
                    
                     <% if (user && (message.user_id === user.id || user.membership_status === 'member' || user.is_admin === true)) { %>
                        Posted by: <%= message.user_username %>
                      <%= message.timestamp.toLocaleDateString() %> 
               <%= message.timestamp.toLocaleTimeString()   %> 
               <% } %>
                    


                     

                </p>






                
             </div><span>          
            
                 <% if (user && user.is_admin) { %>
                       <a href="/messages/<%= message.id %>/delete" 
       onclick="return confirm('Are you sure you want to delete this message?')">
        Delete
    </a>
                        <% } %>
            </span>
        <% }); %>

         
    </div>
</main>

 
    
    
   
 <%- include('partials/footer') %>